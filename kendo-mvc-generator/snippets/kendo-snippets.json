{
    "Kendo Register Form Full": {
  "prefix": "kendo-register",
  "body": [
    "@{",
    "    ViewData[\"Title\"] = \"${1:Register}\";",
    "}",
    "",
    "<div id=\"validation-success\"></div>",
    "",
    "<div class=\"container mt-5\" style=\"border: 1px solid #ccc; width: 70%; padding:20px\">",
    "    <h3>${1:Register}</h3>",
    "    <form id=\"${2:registerform}\"></form>",
    "</div>",
    "",
    "@section Scripts{",
    "<script>",
    "$(document).ready(function () {",
    "",
    "    const validationSuccess = $(\"#validation-success\");",
    "",
    "    $(\"#${2:registerform}\").kendoForm({",
    "",
    "        validatable: {",
    "            validateOnBlur: true,",
    "            validationSummary: false,",
    "            errorTemplate: \"<span class='k-form-error'>#:message#</span>\"",
    "        },",
    "",
    "        items: [",
    "",
    "            { field: \"Name\", label: \"Name:\", validation: { required: { message: \"Please enter your name.\" } } },",
    "",
    "            { field: \"Email\", label: \"Email:\", validation: {",
    "                required: { message: \"Please enter your email.\" },",
    "                email: { message: \"Please enter a valid email address.\" }",
    "            }},",
    "",
    "            {",
    "                field: \"Password\",",
    "                label: \"Password:\",",
    "                validation: { required: { message: \"Please enter password.\" } },",
    "                editor: function (container, options) {",
    "                    $('<input type=\"password\" name=\"' + options.field + '\" autocomplete=\"off\"/>')",
    "                        .appendTo(container)",
    "                        .kendoTextBox();",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"ConfirmPassword\",",
    "                label: \"Confirm Password:\",",
    "                validation: { required: { message: \"Please confirm password.\" } },",
    "                editor: function (container, options) {",
    "                    $('<input type=\"password\" name=\"' + options.field + '\" autocomplete=\"off\"/>')",
    "                        .appendTo(container)",
    "                        .kendoTextBox();",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"Age\",",
    "                label: \"Age:\",",
    "                validation: { required: { message: \"Enter age.\" } },",
    "                editor: function (container, options) {",
    "                    $('<input name=\"' + options.field + '\"/>')",
    "                        .appendTo(container)",
    "                        .kendoNumericTextBox({ format: \"n0\", min: 1, max: 120 });",
    "                }",
    "            },",
    "",
    "            { field: \"Address\", label: \"Address:\" },",
    "            { field: \"Mobile\", label: \"Mobile:\" },",
    "",
    "            {",
    "                field: \"Gender\",",
    "                label: \"Gender:\",",
    "                validation: { required: { message: \"Select gender.\" } },",
    "                editor: function (container, options) {",
    "                    const genders = [\"Male\", \"Female\", \"Other\"];",
    "                    const wrapper = $('<div class=\"k-radio-group\"></div>').appendTo(container);",
    "                    genders.forEach(g => {",
    "                        $('<label class=\"k-radio-label\" style=\"margin-right:15px;\"></label>')",
    "                            .append('<input type=\"radio\" name=\"' + options.field + '\" value=\"' + g + '\" required />')",
    "                            .append(\" \" + g)",
    "                            .appendTo(wrapper);",
    "                    });",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"Hobbies\",",
    "                label: \"Hobbies:\",",
    "                editor: function (container) {",
    "                    const hobbies = [\"Reading\", \"Sports\", \"Music\"];",
    "                    const wrapper = $('<div></div>').appendTo(container);",
    "                    hobbies.forEach(h => {",
    "                        $('<label style=\"margin-right:15px;\"></label>')",
    "                            .append('<input type=\"checkbox\" class=\"hobbyChk\" value=\"' + h + '\"/>')",
    "                            .append(\" \" + h)",
    "                            .appendTo(wrapper);",
    "                    });",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"Country\",",
    "                label: \"Country:\",",
    "                validation: { required: { message: \"Select country.\" } },",
    "                editor: function (container, options) {",
    "                    $('<input name=\"' + options.field + '\"/>')",
    "                        .appendTo(container)",
    "                        .kendoComboBox({",
    "                            placeholder: \"Select country...\",",
    "                            dataSource: [\"India\",\"USA\",\"UK\",\"Canada\",\"Australia\"]",
    "                        });",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"Skills\",",
    "                label: \"Skills:\",",
    "                editor: function (container, options) {",
    "                    $('<input name=\"' + options.field + '\"/>')",
    "                        .appendTo(container)",
    "                        .kendoMultiSelect({",
    "                            placeholder: \"Select skills...\",",
    "                            dataSource: [\"C#\",\"Java\",\"Python\",\"JavaScript\",\"SQL\"]",
    "                        });",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"AcceptTerms\",",
    "                label: \"Terms:\",",
    "                validation: { required: { message: \"You must accept terms and conditions.\" } },",
    "                editor: function (container, options) {",
    "                    const wrapper = $('<div></div>').appendTo(container);",
    "                    $('<label></label>')",
    "                        .append('<input type=\"checkbox\" id=\"chkTerms\" name=\"' + options.field + '\" required />')",
    "                        .append(' I accept the Terms & Conditions')",
    "                        .appendTo(wrapper);",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"image\",",
    "                label: \"Profile Picture:\",",
    "                validation: { required: { message: \"Please select image.\" } },",
    "                editor: function (container, options) {",
    "                    $('<input type=\"file\" name=\"' + options.field + '\" />')",
    "                        .appendTo(container)",
    "                        .kendoUpload({ multiple: false });",
    "                }",
    "            }",
    "        ],",
    "",
    "        buttonsTemplate:",
    "            '<button type=\"submit\" class=\"k-button k-button-lg k-button-solid-success\">Register</button> ' +",
    "            '<button type=\"button\" id=\"btnClearForm\" class=\"k-button k-button-lg\">Clear</button>',",
    "",
    "        validateField: function () {",
    "            validationSuccess.html(\"\");",
    "        },",
    "",
    "        submit: function (e) {",
    "            e.preventDefault();",
    "",
    "            if (!$(\"#chkTerms\").is(\":checked\")) {",
    "                validationSuccess.html(\"<div class='k-messagebox k-messagebox-error'><p>Please accept Terms & Conditions.</p></div>\");",
    "                return;",
    "            }",
    "",
    "            const hobbies = [];",
    "            $(\".hobbyChk:checked\").each(function () { hobbies.push($(this).val()); });",
    "",
    "            const RegisterData = new FormData();",
    "",
    "            RegisterData.append(\"Name\", e.model.Name);",
    "            RegisterData.append(\"Email\", e.model.Email);",
    "            RegisterData.append(\"Password\", e.model.Password);",
    "            RegisterData.append(\"ConfirmPassword\", e.model.ConfirmPassword);",
    "            RegisterData.append(\"Age\", e.model.Age);",
    "            RegisterData.append(\"Address\", e.model.Address);",
    "            RegisterData.append(\"Mobile\", e.model.Mobile);",
    "            RegisterData.append(\"Gender\", e.model.Gender);",
    "            RegisterData.append(\"Country\", e.model.Country);",
    "            RegisterData.append(\"Skills\", e.model.Skills);",
    "            RegisterData.append(\"Hobbies\", hobbies);",
    "            RegisterData.append(\"AcceptTerms\", $(\"#chkTerms\").is(\":checked\"));",
    "",
    "            var imageFile = $(\"input[name=image]\")[0].files[0];",
    "            if (imageFile) {",
    "                RegisterData.append(\"ProfilePicture\", imageFile);",
    "            }",
    "",
    "            $.ajax({",
    "                url: \"${3:/Home/FormTemplate}\",",
    "                method: \"post\",",
    "                contentType: false,",
    "                processData: false,",
    "                data: RegisterData,",
    "                success: function (result) {",
    "                    if (result.success) {",
    "                        validationSuccess.html(\"<div class='k-messagebox k-messagebox-success'><p>\"+result.message+\"</p></div>\");",
    "                    } else {",
    "                        validationSuccess.html(\"<div class='k-messagebox k-messagebox-error'><p>\"+result.message+\"</p></div>\");",
    "                    }",
    "                }",
    "            });",
    "        }",
    "    });",
    "",
    "    $(document).on(\"click\", \"#btnClearForm\", function () {",
    "        $(\"#${2:registerform}\").data(\"kendoForm\").clear();",
    "        validationSuccess.html(\"\");",
    "        $(\".hobbyChk\").prop(\"checked\", false);",
    "        $(\"#chkTerms\").prop(\"checked\", false);",
    "    });",
    "});",
    "</script>",
    "}"
  ],
  "description": "Full Kendo Register Form with Validation, Upload & FormData Submit"
},

"Kendo Login Form Full": {
  "prefix": "kendo-login",
  "body": [
    "@{",
    "    ViewData[\"Title\"] = \"${1:Login}\";",
    "}",
    "",
    "<div id=\"validation-success\"></div>",
    "",
    "<div class=\"container mt-5\" style=\"border: 1px solid #ccc; width: 50%; padding:20px\">",
    "    <h3>${1:Login}</h3>",
    "    <form id=\"${2:loginform}\"></form>",
    "</div>",
    "",
    "@section Scripts{",
    "<script>",
    "$(document).ready(function () {",
    "",
    "    const validationSuccess = $(\"#validation-success\");",
    "",
    "    $(\"#${2:loginform}\").kendoForm({",
    "",
    "        validatable: {",
    "            validateOnBlur: true,",
    "            validationSummary: false,",
    "            errorTemplate: \"<span class='k-form-error'>#:message#</span>\"",
    "        },",
    "",
    "        items: [",
    "",
    "            {",
    "                field: \"Email\",",
    "                label: \"Email:\",",
    "                validation: {",
    "                    required: { message: \"Please enter email.\" },",
    "                    email: { message: \"Please enter valid email.\" }",
    "                }",
    "            },",
    "",
    "            {",
    "                field: \"password\",",
    "                label: \"Password:\",",
    "                validation: { required: { message: \"Please enter password.\" } },",
    "                editor: function (container, options) {",
    "                    $('<input type=\"password\" required=\"required\" data-required-msg=\"Please enter password.\" name=\"' + options.field + '\" autocomplete=\"off\"/>')",
    "                        .appendTo(container)",
    "                        .kendoTextBox();",
    "                }",
    "            }",
    "",
    "        ],",
    "",
    "        buttonsTemplate:",
    "            '<button type=\"submit\" class=\"k-button k-button-lg k-button-solid-primary\">Login</button>'",
    "",
    "        ,submit: function (e) {",
    "            e.preventDefault();",
    "",
    "            const LoginData = new FormData();",
    "            LoginData.append(\"Email\", e.model.Email);",
    "            LoginData.append(\"Password\", e.model.Password);",
    "",
    "            $.ajax({",
    "                url: \"${3:/Account/Login}\",",
    "                method: \"post\",",
    "                contentType: false,",
    "                processData: false,",
    "                data: LoginData,",
    "                success: function (result) {",
    "                    if (result.success) {",
    "                        validationSuccess.html(\"<div class='k-messagebox k-messagebox-success'><p>\" + result.message + \"</p></div>\");",
    "                    } else {",
    "                        validationSuccess.html(\"<div class='k-messagebox k-messagebox-error'><p>\" + result.message + \"</p></div>\");",
    "                    }",
    "                }",
    "            });",
    "        }",
    "",
    "    });",
    "",
    "});",
    "</script>",
    "}"
  ],
  "description": "Kendo Login Form with Email & Password only"
},

"Kendo Grid Image Upload": {
  "prefix": "kendo-grid-crud",
  "body": [
    "@{",
    "    ViewData[\"Title\"] = \"${1:Grid Title}\";",
    "}",
    "",
    "<div id=\"${2:gridId}\"></div>",
    "<div id=\"notification\"></div>",
    "",
    "@section Scripts{",
    "<script>",
    "$(document).ready(function () {",
    "",
    "    // Image Upload Editor",
    "    function imageUploadEditor(container, options) {",
    "        $('<input name=\"' + options.field + '\" type=\"file\" />')",
    "            .appendTo(container)",
    "            .kendoUpload({",
    "                async: {",
    "                    saveUrl: \"${3:/Controller/UploadImage}\",",
    "                    autoUpload: true",
    "                },",
    "                multiple: false,",
    "                success: function (e) {",
    "                    if (e.response && e.response.fileName) {",
    "                        options.model.${4:Image} = e.response.fileName;",
    "                    }",
    "                }",
    "            });",
    "    }",
    "",
    "    var dataSource = new kendo.data.DataSource({",
    "        transport: {",
    "",
    "            read: {",
    "                url: \"${5:/Controller/Read}\",",
    "                dataType: \"json\"",
    "            },",
    "",
    "            create: {",
    "                url: \"${6:/Controller/Create}\",",
    "                type: \"POST\",",
    "                contentType: \"application/json\"",
    "            },",
    "",
    "            update: {",
    "                url: \"${7:/Controller/Update}\",",
    "                type: \"POST\",",
    "                contentType: \"application/json\"",
    "            },",
    "",
    "            destroy: {",
    "                url: \"${8:/Controller/Delete}\",",
    "                type: \"POST\",",
    "                contentType: \"application/json\"",
    "            },",
    "",
    "            parameterMap: function (data, type) {",
    "                if (type !== \"read\") {",
    "                    var payload = data.models && data.models.length",
    "                        ? data.models[0]",
    "                        : data;",
    "",
    "                    if (type === \"create\" && !payload.${9:Id}) {",
    "                        delete payload.${9:Id};",
    "                    }",
    "",
    "                    return JSON.stringify(payload);",
    "                }",
    "            }",
    "        },",
    "",
    "        pageSize: ${10:5},",
    "",
    "        schema: {",
    "            model: {",
    "                id: \"${9:Id}\",",
    "                fields: {",
    "                    ${9:Id}: { type: \"number\", editable: false, nullable: true },",
    "                    ${11:Name}: { type: \"string\", validation: { required: true } },",
    "                    ${4:Image}: { type: \"string\", validation: { required: true } }",
    "                }",
    "            }",
    "        }",
    "    });",
    "",
    "    $(\"#${2:gridId}\").kendoGrid({",
    "        dataSource: dataSource,",
    "",
    "        columns: [",
    "            { field: \"${9:Id}\", title: \"ID\" },",
    "            { field: \"${11:Name}\", title: \"Name\" },",
    "            {",
    "                field: \"${4:Image}\",",
    "                title: \"Image\",",
    "                editor: imageUploadEditor,",
    "                template: \"<img src='/uploads/#=${4:Image}#' style='width:50px;height:50px;' />\"",
    "            },",
    "            { command: [\"edit\", \"destroy\"], title: \"Actions\" }",
    "        ],",
    "",
    "        toolbar: [\"create\"],",
    "        editable: \"popup\",",
    "        pageable: true,",
    "        sortable: true,",
    "        filterable: true,",
    "",
    "        edit: function (e) {",
    "            var popup = e.container.data(\"kendoWindow\");",
    "            var btn = e.container.find(\".k-grid-update\");",
    "",
    "            if (e.model.isNew()) {",
    "                popup.title(\"Add New Record\");",
    "                btn.text(\"Add\");",
    "            } else {",
    "                popup.title(\"Edit Record\");",
    "                btn.text(\"Update\");",
    "            }",
    "        }",
    "    });",
    "",
    "    // Notification",
    "    $(\"#notification\").kendoNotification({",
    "        position: { pinned: true, top: 30, right: 30 },",
    "        autoHideAfter: 3000",
    "    });",
    "",
    "    dataSource.bind(\"error\", function () {",
    "        $(\"#notification\").data(\"kendoNotification\")",
    "            .show(\"Error occurred!\", \"error\");",
    "    });",
    "",
    "    dataSource.bind(\"requestEnd\", function (e) {",
    "        var msg = \"\";",
    "",
    "        if (e.type === \"create\") msg = \"Created successfully!\";",
    "        if (e.type === \"update\") msg = \"Updated successfully!\";",
    "        if (e.type === \"destroy\") msg = \"Deleted successfully!\";",
    "",
    "        if (msg) {",
    "            $(\"#notification\").data(\"kendoNotification\").show(msg, \"success\");",
    "            $(\"#${2:gridId}\").data(\"kendoGrid\").dataSource.read();",
    "        }",
    "    });",
    "",
    "    $(\"#${2:gridId}\").on(\"click\", \".k-grid-cancel-changes\", function () {",
    "        dataSource.cancelChanges();",
    "    });",
    "",
    "});",
    "</script>",
    "}"
  ],
  "description": "Kendo Grid with Image Upload, Popup CRUD & Notification"
},

"Kendo Grid View Redirect": {
  "prefix": "kendo-grid-single",
  "body": [
    "@{",
    "    ViewData[\"Title\"] = \"${1:Grid Title}\";",
    "}",
    "",
    "<div id=\"${2:gridId}\"></div>",
    "",
    "@section Scripts{",
    "    <script>",
    "        $(document).ready(function () {",
    "",
    "            var dataSource = new kendo.data.DataSource({",
    "                transport: {",
    "                    read: {",
    "                        url: \"${3:/Controller/GetData}\",",
    "                        dataType: \"json\"",
    "                    }",
    "                },",
    "",
    "                pageSize: ${4:5},",
    "",
    "                schema: {",
    "                    model: {",
    "                        id: \"${5:Id}\",",
    "                        fields: {",
    "                            ${5:Id}: { type: \"number\" },",
    "                            ${6:Name}: { type: \"string\" },",
    "                            ${7:City}: { type: \"string\" }",
    "                        }",
    "                    }",
    "                }",
    "            });",
    "",
    "            $(\"#${2:gridId}\").kendoGrid({",
    "                dataSource: dataSource,",
    "",
    "                pageable: true,",
    "                sortable: true,",
    "                filterable: true,",
    "",
    "                columns: [",
    "                    { field: \"${5:Id}\", title: \"ID\" },",
    "                    { field: \"${6:Name}\", title: \"Name\" },",
    "                    { field: \"${7:City}\", title: \"City\" },",
    "                    {",
    "                        title: \"Action\",",
    "                        template: `",
    "                            <button class=\"k-button k-primary view-btn\">",
    "                                ${8:View Details}",
    "                            </button>",
    "                        `",
    "                    }",
    "                ]",
    "            });",
    "",
    "            // Redirect on button click",
    "            $(\"#${2:gridId}\").on(\"click\", \".view-btn\", function () {",
    "                var grid = $(\"#${2:gridId}\").data(\"kendoGrid\");",
    "                var dataItem = grid.dataItem($(this).closest(\"tr\"));",
    "",
    "                window.location.href = \"${9:/Controller/Details/}\" + dataItem.${5:Id};",
    "            });",
    "",
    "        });",
    "    </script>",
    "}"
  ],
  "description": "Kendo Grid with View Button and Redirect"
},

"Kendo Grid ReadOnly": {
  "prefix": "kendo-grid-readonly",
  "body": [
    "@{",
    "    ViewData[\"Title\"] = \"${1:Grid Template}\";",
    "}",
    "",
    "<div id=\"${2:grid}\"></div>",
    "",
    "@section Scripts{",
    "    <script>",
    "        $(document).ready(function () {",
    "",
    "            // Read Only DataSource",
    "            var dataSource = new kendo.data.DataSource({",
    "                transport: {",
    "                    read: {",
    "                        url: \"${3:https://localhost:7285/MyCity/City_Read}\",",
    "                        dataType: \"json\"",
    "                    }",
    "                },",
    "",
    "                pageSize: ${4:5},",
    "",
    "                schema: {",
    "                    model: {",
    "                        id: \"${5:CityId}\",",
    "                        fields: {",
    "                            ${5:CityId}: { type: \"number\" },",
    "                            ${6:CityName}: { type: \"string\" },",
    "                            ${7:Image}: { type: \"string\" }",
    "                        }",
    "                    }",
    "                }",
    "            });",
    "",
    "            // Kendo Grid",
    "            $(\"#${2:grid}\").kendoGrid({",
    "                dataSource: dataSource,",
    "",
    "                columns: [",
    "                    { field: \"${5:CityId}\", title: \"City ID\" },",
    "                    { field: \"${6:CityName}\", title: \"City Name\" },",
    "                    {",
    "                        field: \"${7:Image}\",",
    "                        title: \"Image\",",
    "                        template: function (dataItem) {",
    "                            return dataItem.${7:Image}",
    "                                ? \"<img src='/uploads/\" + dataItem.${7:Image} + \"' width='80' height='60' />\"",
    "                                : \"No Image\";",
    "                        }",
    "                    }",
    "                ],",
    "",
    "                pageable: true,",
    "                sortable: true,",
    "                filterable: true,",
    "                searchable: true",
    "            });",
    "",
    "        });",
    "    </script>",
    "}"
  ],
  "description": "Kendo UI Read-Only Grid with Image Template"
},

"Kendo Dropdown Editor": {
  "prefix": "kendo-dropdown-m",
  "body": [
    "// Dropdown Editor",
    "function ${1:typeDropDownEditor}(container, options) {",
    "    $('<input required name=\"' + options.field + '\" />')",
    "        .appendTo(container)",
    "        .kendoDropDownList({",
    "            dataTextField: \"text\",",
    "            dataValueField: \"value\",",
    "            optionLabel: \"${2:Select Type}\",",
    "            dataSource: [",
    "                { text: \"${3:Metro City}\", value: \"${3:Metro City}\" },",
    "                { text: \"${4:Small City}\", value: \"${4:Small City}\" },",
    "                { text: \"${5:Village}\", value: \"${5:Village}\" }",
    "            ]",
    "        });",
    "}"
  ],
  "description": "Kendo UI DropDownList Editor for Grid/Form"
},

"Kendo Radio Editor": {
  "prefix": "kendo-radio-m",
  "body": [
    "// Radio Button Editor",
    "function ${1:statusRadioEditor}(container, options) {",
    "    var html = `",
    "        <div style=\"padding-top:10px;\">",
    "            <label>",
    "                <input type=\"radio\"",
    "                       name=\"${options.field}\"",
    "                       value=\"${2:Active}\" /> ${2:Active}",
    "            </label>",
    "",
    "            <label style=\"margin-left:20px;\">",
    "                <input type=\"radio\"",
    "                       name=\"${options.field}\"",
    "                       value=\"${3:Inactive}\" /> ${3:Inactive}",
    "            </label>",
    "        </div>",
    "    `;",
    "",
    "    $(html).appendTo(container);",
    "",
    "    // Set existing value",
    "    container.find(\"input[value='\" + options.model.${4:Status} + \"']\")",
    "        .prop(\"checked\", true);",
    "}"
  ],
  "description": "Kendo UI Radio Button Editor for Grid/Form"
},

"Kendo Checkbox Group Editor": {
  "prefix": "kendo-checkbox-m",
  "body": [
    "// Checkbox Group Editor",
    "function ${1:statusCheckboxEditor}(container, options) {",
    "",
    "    // Active checkbox",
    "    $('<div style=\"margin-bottom:5px;\">')",
    "        .append(",
    "            '<label><input type=\"checkbox\" name=\"IsActive\" /> ${2:Active}</label>'",
    "        )",
    "        .appendTo(container);",
    "",
    "    // Verified checkbox",
    "    $('<div style=\"margin-bottom:5px;\">')",
    "        .append(",
    "            '<label><input type=\"checkbox\" name=\"IsVerified\" /> ${3:Verified}</label>'",
    "        )",
    "        .appendTo(container);",
    "",
    "    // Deleted checkbox",
    "    $('<div>')",
    "        .append(",
    "            '<label><input type=\"checkbox\" name=\"IsDeleted\" /> ${4:Deleted}</label>'",
    "        )",
    "        .appendTo(container);",
    "",
    "    // Set existing values",
    "    container.find(\"input[name='IsActive']\")",
    "        .prop(\"checked\", options.model.IsActive);",
    "",
    "    container.find(\"input[name='IsVerified']\")",
    "        .prop(\"checked\", options.model.IsVerified);",
    "",
    "    container.find(\"input[name='IsDeleted']\")",
    "        .prop(\"checked\", options.model.IsDeleted);",
    "",
    "    // Update model on change",
    "    container.find(\"input[type='checkbox']\").change(function () {",
    "        options.model.set($(this).attr(\"name\"), $(this).is(\":checked\"));",
    "    });",
    "}"
  ],
  "description": "Kendo UI Checkbox Group Editor (Multiple Boolean Fields)"
},

"Kendo MultiSelect Editor": {
  "prefix": "kendo-multiselect-m",
  "body": [
    "// MultiSelect Editor",
    "function ${1:stateMultiSelectEditor}(container, options) {",
    "    $('<input name=\"' + options.field + '\" />')",
    "        .appendTo(container)",
    "        .kendoMultiSelect({",
    "            placeholder: \"${2:Select States}\",",
    "            dataTextField: \"text\",",
    "            dataValueField: \"value\",",
    "            dataSource: [",
    "                { text: \"${3:Gujarat}\", value: \"${3:Gujarat}\" },",
    "                { text: \"${4:Maharashtra}\", value: \"${4:Maharashtra}\" },",
    "                { text: \"${5:Rajasthan}\", value: \"${5:Rajasthan}\" },",
    "                { text: \"${6:Delhi}\", value: \"${6:Delhi}\" }",
    "            ]",
    "        });",
    "}"
  ],
  "description": "Kendo UI MultiSelect Editor for Grid/Form"
},

"Kendo Date Editor": {
  "prefix": "kendo-date-editor-m",
  "body": [
    "// DatePicker Editor",
    "function ${1:dateEditor}(container, options) {",
    "    $('<input name=\"' + options.field + '\"/>')",
    "        .appendTo(container)",
    "        .kendoDatePicker({",
    "            format: \"${2:dd/MM/yyyy}\"",
    "        });",
    "}"
  ],
  "description": "Kendo UI DatePicker Editor for Grid/Form"
},

"Kendo Date Editor Max": {
  "prefix": "kendo-date-max-m",
  "body": [
    "// DatePicker Editor with Max Date",
    "function ${1:dateEditor}(container, options) {",
    "    $('<input name=\"' + options.field + '\"/>')",
    "        .appendTo(container)",
    "        .kendoDatePicker({",
    "            format: \"${2:dd/MM/yyyy}\",",
    "            max: new Date()   // current date tak allow",
    "        });",
    "}"
  ],
  "description": "Kendo UI DatePicker with Max Date Restriction"
},

"Kendo Date Editor Range": {
  "prefix": "kendo-date-range-m",
  "body": [
    "// DatePicker Editor with Min & Max Range",
    "function ${1:dateEditor}(container, options) {",
    "    $('<input name=\"' + options.field + '\"/>')",
    "        .appendTo(container)",
    "        .kendoDatePicker({",
    "            format: \"${2:dd/MM/yyyy}\",",
    "",
    "            // Start Date",
    "            min: new Date(${3:2026}, ${4:0}, ${5:1}, ${6:0}, ${7:0}, ${8:0}),",
    "",
    "            // End Date",
    "            max: new Date(${9:2026}, ${10:11}, ${11:31}, ${12:23}, ${13:59}, ${14:59})",
    "        });",
    "}"
  ],
  "description": "Kendo UI DatePicker with Min & Max Date Range"
},

"Kendo Date Editor Last 7 Days": {
  "prefix": "kendo-date-last7-m",
  "body": [
    "// DatePicker Editor (Last 7 Days Only)",
    "function ${1:dateEditor}(container, options) {",
    "",
    "    var today = new Date();",
    "",
    "    var last7Days = new Date();",
    "    last7Days.setDate(today.getDate() - 7);",
    "",
    "    $('<input name=\"' + options.field + '\"/>')",
    "        .appendTo(container)",
    "        .kendoDatePicker({",
    "            format: \"${2:dd/MM/yyyy}\",",
    "            min: last7Days,",
    "            max: today",
    "        });",
    "}"
  ],
  "description": "Kendo UI DatePicker - Last 7 Days Only"
},

"Kendo Date Editor Next 30 Days": {
  "prefix": "kendo-date-next30-m",
  "body": [
    "// DatePicker Editor (Next 30 Days Only)",
    "function ${1:dateEditor}(container, options) {",
    "",
    "    var today = new Date();",
    "",
    "    var next30Days = new Date();",
    "    next30Days.setDate(today.getDate() + 30);",
    "",
    "    $('<input name=\"' + options.field + '\"/>')",
    "        .appendTo(container)",
    "        .kendoDatePicker({",
    "            format: \"${2:dd/MM/yyyy}\",",
    "            min: today,",
    "            max: next30Days",
    "        });",
    "}"
  ],
  "description": "Kendo UI DatePicker - Next 30 Days Only"
},

"Kendo File Upload Editor": {
  "prefix": "kendo-file-upload-m",
  "body": [
    "// File Upload Editor",
    "function ${1:fileUploadEditor}(container, options) {",
    "",
    "    $('<input type=\"file\" name=\"' + options.field + '\" />')",
    "        .appendTo(container)",
    "        .kendoUpload({",
    "            async: {",
    "                saveUrl: \"${2:/File/Upload}\",",
    "                removeUrl: \"${3:/File/Remove}\",",
    "                autoUpload: true",
    "            },",
    "",
    "            multiple: false,",
    "",
    "            success: function (e) {",
    "                if (e.response && e.response.fileName) {",
    "                    options.model.set(options.field, e.response.fileName);",
    "                }",
    "            },",
    "",
    "            error: function (e) {",
    "                alert(\"${4:Upload failed}\");",
    "            }",
    "        });",
    "}"
  ],
  "description": "Kendo UI File Upload Editor for Grid/Form"
},

"Kendo Grid Column Formats": {
  "prefix": "kendo-grid-formats",
  "body": [
    "columns: [",
    "",
    "    // Number Format",
    "    {",
    "        field: \"${1:Price}\",",
    "        title: \"${2:Price}\",",
    "        format: \"{0:n2}\"",
    "    },",
    "",
    "    // Currency Format",
    "    {",
    "        field: \"${3:Amount}\",",
    "        title: \"${4:Amount}\",",
    "        format: \"{0:c}\"",
    "    },",
    "",
    "    // Date Format",
    "    {",
    "        field: \"${5:CreatedDate}\",",
    "        title: \"${6:Date}\",",
    "        format: \"{0:dd/MM/yyyy}\"",
    "    },",
    "",
    "    // Time Format",
    "    {",
    "        field: \"${7:CreatedTime}\",",
    "        title: \"${8:Time}\",",
    "        format: \"{0:hh:mm tt}\"",
    "    },",
    "",
    "    // DateTime Format",
    "    {",
    "        field: \"${9:FullDateTime}\",",
    "        title: \"${10:Date Time}\",",
    "        format: \"{0:dd/MM/yyyy hh:mm tt}\"",
    "    },",
    "",
    "    // Percentage Format",
    "    {",
    "        field: \"${11:Discount}\",",
    "        title: \"${12:Discount}\",",
    "        format: \"{0:p}\"",
    "    },",
    "",
    "    // Image Format",
    "    {",
    "        field: \"${13:Image}\",",
    "        title: \"Image\",",
    "        template: \"<img src='/uploads/#=${13:Image}#' width='80' height='60' />\"",
    "    },",
    "",
    "    // Hyperlink Format",
    "    {",
    "        field: \"${14:Website}\",",
    "        title: \"Website\",",
    "        template: \"<a href='#=${14:Website}#' target='_blank'>Open Link</a>\"",
    "    },",
    "",
    "    // Boolean Format",
    "    {",
    "        field: \"${15:IsActive}\",",
    "        title: \"Status\",",
    "        template: \"#= ${15:IsActive} ? 'Active' : 'Inactive' #\"",
    "    },",
    "",
    "    // Status Badge",
    "    {",
    "        field: \"${16:Status}\",",
    "        title: \"Status\",",
    "        template: function(dataItem) {",
    "            if (dataItem.${16:Status} == \"Approved\") {",
    "                return \"<span style='color:green;'>Approved</span>\";",
    "            } else {",
    "                return \"<span style='color:red;'>Pending</span>\";",
    "            }",
    "        }",
    "    },",
    "",
    "    // Dropdown Display",
    "    {",
    "        field: \"${17:StateName}\",",
    "        title: \"State\"",
    "    },",
    "",
    "    // Radio Display",
    "    {",
    "        field: \"${18:Gender}\",",
    "        title: \"Gender\"",
    "    },",
    "",
    "    // Checkbox Display",
    "    {",
    "        field: \"${19:TermsAccepted}\",",
    "        title: \"Accepted\",",
    "        template: \"<input type='checkbox' #= ${19:TermsAccepted} ? 'checked' : '' # disabled />\"",
    "    },",
    "",
    "    // Button Template",
    "    {",
    "        title: \"Action\",",
    "        template: \"<button class='k-button view-btn'>${20:View}</button>\"",
    "    },",
    "",
    "    // Command Buttons",
    "    {",
    "        command: [\"edit\", \"destroy\"],",
    "        title: \"Actions\"",
    "    }",
    "",
    "]"
  ],
  "description": "Kendo Grid Column Formats (All Common Types)"
}

}