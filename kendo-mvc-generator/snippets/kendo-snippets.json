{
  "Kendo Grid": {
    "prefix": "kendo-grid",
    "body": [
      "@{",
      "    ViewBag.Title = \"${1:Items}\";",
      "}",
      "",
      "<div id=\"kendoGrid\"></div>",
      "",
      "@section Scripts {",
      "<script>",
      "$(document).ready(function () {",
      "    $(\"#kendoGrid\").kendoGrid({",
      "        dataSource: {",
      "            transport: {",
      "                read:    { url: \"@Url.Action(\\\"Read\\\",   \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "                create:  { url: \"@Url.Action(\\\"Create\\\", \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "                update:  { url: \"@Url.Action(\\\"Update\\\", \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "                destroy: { url: \"@Url.Action(\\\"Delete\\\", \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "                parameterMap: function (data, op) {",
      "                    return op !== \"read\" && data.models ? JSON.stringify(data.models) : JSON.stringify(data);",
      "                }",
      "            },",
      "            pageSize: 20,",
      "            serverPaging: true,",
      "            serverSorting: true,",
      "            serverFiltering: true,",
      "            schema: {",
      "                model: {",
      "                    id: \"${3:Id}\",",
      "                    fields: {",
      "                        ${3:Id}:   { type: \"number\", editable: false },",
      "                        ${4:Name}: { type: \"string\", validation: { required: true } }",
      "                    }",
      "                },",
      "                data: \"data\", total: \"total\", errors: \"errors\"",
      "            }",
      "        },",
      "        height: 600,",
      "        pageable: { refresh: true, pageSizes: [10, 20, 50] },",
      "        sortable: true,",
      "        filterable: { mode: \"row\" },",
      "        resizable: true,",
      "        toolbar: [\"create\", \"excel\", \"pdf\"],",
      "        editable: { mode: \"popup\", confirmation: true },",
      "        columns: [",
      "            { field: \"${3:Id}\",   title: \"ID\",   width: 70, hidden: true },",
      "            { field: \"${4:Name}\", title: \"Name\", width: 200 },",
      "            { command: [\"edit\", \"destroy\"], title: \"Actions\", width: 160 }",
      "        ]",
      "    });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo UI Grid with full CRUD DataSource for ASP.NET MVC"
  },

  "Kendo Form": {
    "prefix": "kendo-form",
    "body": [
      "@model ${1:ModelName}",
      "@{ ViewBag.Title = \"${1:ModelName} Form\"; }",
      "",
      "<div style=\"max-width:700px;margin:30px auto;\">",
      "    <div id=\"kendoForm\"></div>",
      "</div>",
      "",
      "@section Scripts {",
      "<script>",
      "$(document).ready(function () {",
      "    $(\"#kendoForm\").kendoForm({",
      "        formData: @Html.Raw(Json.Serialize(Model)),",
      "        orientation: \"vertical\",",
      "        items: [",
      "            { field: \"${2:Name}\",  label: { text: \"${3:Name}\" },  editor: \"TextBox\",        validation: { required: true } },",
      "            { field: \"${4:Email}\", label: { text: \"${5:Email}\" }, editor: \"TextBox\",        validation: { required: true, email: true } },",
      "            { field: \"${6:Age}\",   label: { text: \"${7:Age}\" },   editor: \"NumericTextBox\", editorOptions: { min: 0, format: \"n0\" } }",
      "        ],",
      "        validatable: { validateOnBlur: true, validationSummary: true },",
      "        submit: function (ev) {",
      "            ev.preventDefault();",
      "            $.ajax({",
      "                url: \"@Url.Action(\\\"Save\\\", \\\"${8:Controller}\\\")\",",
      "                type: \"POST\",",
      "                contentType: \"application/json\",",
      "                data: JSON.stringify(ev.sender.toJSON()),",
      "                success: function (r) {",
      "                    if (r.success) window.location.href = \"@Url.Action(\\\"Index\\\", \\\"${8:Controller}\\\")\";",
      "                    else kendo.alert(r.message);",
      "                }",
      "            });",
      "        }",
      "    });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo UI Form with validation for ASP.NET MVC"
  },

  "Kendo Login": {
    "prefix": "kendo-login",
    "body": [
      "@{ ViewBag.Title = \"Login\"; Layout = null; }",
      "<!DOCTYPE html>",
      "<html lang=\"en\">",
      "<head>",
      "    <meta charset=\"utf-8\" />",
      "    <title>Login</title>",
      "    <link rel=\"stylesheet\" href=\"https://kendo.cdn.telerik.com/2024.1.130/styles/kendo.default-main.min.css\" />",
      "</head>",
      "<body style=\"display:flex;align-items:center;justify-content:center;min-height:100vh;background:#1e3c72;\">",
      "<div style=\"background:#fff;padding:48px 40px;border-radius:12px;max-width:420px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.25);\">",
      "    <h2 style=\"text-align:center;margin-bottom:30px;\">Sign In</h2>",
      "    <form id=\"loginForm\" novalidate>",
      "        <div class=\"k-form-field\">",
      "            <label>Email</label>",
      "            <input id=\"Email\" name=\"Email\" type=\"email\" class=\"k-textbox k-input\" required />",
      "        </div>",
      "        <div class=\"k-form-field\">",
      "            <label>Password</label>",
      "            <input id=\"Password\" name=\"Password\" type=\"password\" class=\"k-textbox k-input\" required />",
      "        </div>",
      "        <button type=\"submit\" class=\"k-button k-button-solid-primary\" style=\"width:100%;margin-top:16px;\">Login</button>",
      "    </form>",
      "</div>",
      "<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"></script>",
      "<script src=\"https://kendo.cdn.telerik.com/2024.1.130/js/kendo.all.min.js\"></script>",
      "<script>",
      "$(document).ready(function () {",
      "    var v = $(\"#loginForm\").kendoValidator().data(\"kendoValidator\");",
      "    $(\"#loginForm\").on(\"submit\", function (e) {",
      "        e.preventDefault();",
      "        if (!v.validate()) return;",
      "        $.ajax({",
      "            url: \"@Url.Action(\\\"Login\\\", \\\"Account\\\")\",",
      "            type: \"POST\", contentType: \"application/json\",",
      "            data: JSON.stringify({ Email: $(\"#Email\").val(), Password: $(\"#Password\").val() }),",
      "            success: function (r) { if (r.success) location.href = r.redirectUrl; else kendo.alert(r.message); }",
      "        });",
      "    });",
      "});",
      "</script>",
      "</body></html>"
    ],
    "description": "Kendo UI Login Page for ASP.NET MVC"
  },

  "Kendo Register": {
    "prefix": "kendo-register",
    "body": [
      "@{ ViewBag.Title = \"Register\"; }",
      "",
      "<div style=\"max-width:560px;margin:40px auto;background:#fff;padding:40px;border-radius:10px;box-shadow:0 4px 24px rgba(0,0,0,.1);\">",
      "    <h2>Create Account</h2>",
      "    <form id=\"registerForm\" novalidate>",
      "        @Html.AntiForgeryToken()",
      "        <div class=\"k-form-field\"><label>First Name</label>",
      "            <input id=\"FirstName\" name=\"FirstName\" class=\"k-textbox k-input\" required /></div>",
      "        <div class=\"k-form-field\"><label>Last Name</label>",
      "            <input id=\"LastName\" name=\"LastName\" class=\"k-textbox k-input\" required /></div>",
      "        <div class=\"k-form-field\"><label>Email</label>",
      "            <input id=\"Email\" name=\"Email\" type=\"email\" class=\"k-textbox k-input\" required /></div>",
      "        <div class=\"k-form-field\"><label>Password</label>",
      "            <input id=\"Password\" name=\"Password\" type=\"password\" class=\"k-textbox k-input\" required /></div>",
      "        <div class=\"k-form-field\"><label>Confirm Password</label>",
      "            <input id=\"ConfirmPassword\" name=\"ConfirmPassword\" type=\"password\" class=\"k-textbox k-input\" required /></div>",
      "        <button type=\"submit\" class=\"k-button k-button-solid-primary\" style=\"width:100%;margin-top:20px;\">Register</button>",
      "    </form>",
      "</div>",
      "",
      "@section Scripts {",
      "<script>",
      "$(document).ready(function () {",
      "    var v = $(\"#registerForm\").kendoValidator({",
      "        rules: {",
      "            confirmpassword: function (i) {",
      "                return i.attr(\"id\") !== \"ConfirmPassword\" || i.val() === $(\"#Password\").val();",
      "            }",
      "        },",
      "        messages: { confirmpassword: \"Passwords do not match\" }",
      "    }).data(\"kendoValidator\");",
      "    $(\"#registerForm\").on(\"submit\", function (e) {",
      "        e.preventDefault();",
      "        if (!v.validate()) return;",
      "        $.ajax({",
      "            url: \"@Url.Action(\\\"Register\\\", \\\"Account\\\")\",",
      "            type: \"POST\", contentType: \"application/json\",",
      "            data: JSON.stringify({",
      "                FirstName: $(\"#FirstName\").val(), LastName: $(\"#LastName\").val(),",
      "                Email: $(\"#Email\").val(), Password: $(\"#Password\").val()",
      "            }),",
      "            success: function (r) { if (r.success) location.href = r.redirectUrl; else kendo.alert(r.message); }",
      "        });",
      "    });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo UI Registration Page for ASP.NET MVC"
  },

  "Kendo DataSource": {
    "prefix": "kendo-datasource",
    "body": [
      "var ${1:ds} = new kendo.data.DataSource({",
      "    transport: {",
      "        read:    { url: \"@Url.Action(\\\"Read\\\",   \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "        create:  { url: \"@Url.Action(\\\"Create\\\", \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "        update:  { url: \"@Url.Action(\\\"Update\\\", \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "        destroy: { url: \"@Url.Action(\\\"Delete\\\", \\\"${2:Controller}\\\")\", type: \"POST\", dataType: \"json\", contentType: \"application/json\" },",
      "        parameterMap: function (data, op) {",
      "            return op !== \"read\" && data.models ? JSON.stringify(data.models) : JSON.stringify(data);",
      "        }",
      "    },",
      "    pageSize: ${3:20},",
      "    serverPaging: true,",
      "    serverSorting: true,",
      "    serverFiltering: true,",
      "    schema: {",
      "        model: {",
      "            id: \"${4:Id}\",",
      "            fields: {",
      "                ${4:Id}: { type: \"number\", editable: false },",
      "                ${5:Name}: { type: \"string\" }",
      "            }",
      "        },",
      "        data: \"data\", total: \"total\", errors: \"errors\"",
      "    }",
      "});"
    ],
    "description": "Kendo DataSource with CRUD transport for ASP.NET MVC"
  },

  "Kendo Chart": {
    "prefix": "kendo-chart",
    "body": [
      "<div id=\"${1:kendoChart}\"></div>",
      "",
      "@section Scripts {",
      "<script>",
      "$(document).ready(function () {",
      "    $(\"#${1:kendoChart}\").kendoChart({",
      "        title: { text: \"${2:Chart Title}\" },",
      "        legend: { position: \"bottom\" },",
      "        dataSource: {",
      "            transport: {",
      "                read: { url: \"@Url.Action(\\\"ChartData\\\", \\\"${3:Controller}\\\")\", dataType: \"json\" }",
      "            },",
      "            schema: { data: \"data\" }",
      "        },",
      "        series: [{ type: \"${4|column,bar,line,area,pie,donut|}\", field: \"${5:Value}\", name: \"${6:Series}\" }],",
      "        categoryAxis: { field: \"${7:Category}\", labels: { rotation: -45 } },",
      "        tooltip: { visible: true, format: \"{0}\" }",
      "    });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo UI Chart component"
  },

  "Kendo NumericTextBox": {
    "prefix": "kendo-numeric",
    "body": [
      "<input id=\"${1:fieldId}\" name=\"${1:fieldId}\" />",
      "<script>",
      "$(\"#${1:fieldId}\").kendoNumericTextBox({",
      "    min: ${2:0},",
      "    max: ${3:100},",
      "    decimals: ${4:0},",
      "    format: \"${5:n0}\",",
      "    change: function (e) { console.log(\"Value:\", e.sender.value()); }",
      "});",
      "</script>"
    ],
    "description": "Kendo NumericTextBox widget"
  },

  "Kendo DatePicker": {
    "prefix": "kendo-datepicker",
    "body": [
      "<input id=\"${1:fieldId}\" name=\"${1:fieldId}\" />",
      "<script>",
      "$(\"#${1:fieldId}\").kendoDatePicker({",
      "    format: \"${2:MM/dd/yyyy}\",",
      "    min: new Date(\"${3:01/01/1900}\"),",
      "    max: new Date(\"${4:12/31/2099}\"),",
      "    change: function (e) { console.log(\"Date:\", e.sender.value()); }",
      "});",
      "</script>"
    ],
    "description": "Kendo DatePicker widget"
  },

  "Kendo DateTimePicker": {
    "prefix": "kendo-datetimepicker",
    "body": [
      "<input id=\"${1:fieldId}\" name=\"${1:fieldId}\" />",
      "<script>",
      "$(\"#${1:fieldId}\").kendoDateTimePicker({",
      "    format: \"${2:MM/dd/yyyy HH:mm}\",",
      "    change: function (e) { console.log(\"DateTime:\", e.sender.value()); }",
      "});",
      "</script>"
    ],
    "description": "Kendo DateTimePicker widget"
  },

  "Kendo DropDownList": {
    "prefix": "kendo-dropdown",
    "body": [
      "<input id=\"${1:fieldId}\" name=\"${1:fieldId}\" />",
      "<script>",
      "$(\"#${1:fieldId}\").kendoDropDownList({",
      "    dataTextField: \"${2:Text}\",",
      "    dataValueField: \"${3:Value}\",",
      "    optionLabel: \"-- Select ${4:Item} --\",",
      "    dataSource: {",
      "        transport: {",
      "            read: { url: \"@Url.Action(\\\"GetList\\\", \\\"${5:Controller}\\\")\", dataType: \"json\" }",
      "        }",
      "    },",
      "    change: function (e) { console.log(\"Selected:\", e.sender.value()); }",
      "});",
      "</script>"
    ],
    "description": "Kendo DropDownList widget"
  },

  "Kendo MultiSelect": {
    "prefix": "kendo-multiselect",
    "body": [
      "<select id=\"${1:fieldId}\" name=\"${1:fieldId}\" multiple></select>",
      "<script>",
      "$(\"#${1:fieldId}\").kendoMultiSelect({",
      "    dataTextField: \"${2:Text}\",",
      "    dataValueField: \"${3:Value}\",",
      "    placeholder: \"Select ${4:items}...\",",
      "    dataSource: {",
      "        transport: {",
      "            read: { url: \"@Url.Action(\\\"GetList\\\", \\\"${5:Controller}\\\")\", dataType: \"json\" }",
      "        }",
      "    }",
      "});",
      "</script>"
    ],
    "description": "Kendo MultiSelect widget"
  },

  "Kendo AutoComplete": {
    "prefix": "kendo-autocomplete",
    "body": [
      "<input id=\"${1:fieldId}\" name=\"${1:fieldId}\" />",
      "<script>",
      "$(\"#${1:fieldId}\").kendoAutoComplete({",
      "    dataTextField: \"${2:Name}\",",
      "    minLength: 2,",
      "    filter: \"contains\",",
      "    dataSource: {",
      "        serverFiltering: true,",
      "        transport: {",
      "            read: { url: \"@Url.Action(\\\"Search\\\", \\\"${3:Controller}\\\")\", dataType: \"json\",",
      "                    data: function () { return { q: $(\"#${1:fieldId}\").val() }; } }",
      "        }",
      "    }",
      "});",
      "</script>"
    ],
    "description": "Kendo AutoComplete widget"
  },

  "Kendo Upload": {
    "prefix": "kendo-upload",
    "body": [
      "<input name=\"files\" id=\"${1:kendoUpload}\" type=\"file\" />",
      "",
      "@section Scripts {",
      "<script>",
      "$(document).ready(function () {",
      "    $(\"#${1:kendoUpload}\").kendoUpload({",
      "        async: {",
      "            saveUrl:   \"@Url.Action(\\\"Save\\\",   \\\"${2:Files}\\\")\",",
      "            removeUrl: \"@Url.Action(\\\"Remove\\\", \\\"${2:Files}\\\")\",",
      "            autoUpload: true",
      "        },",
      "        multiple: ${3:true},",
      "        validation: {",
      "            allowedExtensions: [\"${4:.jpg}\", \"${5:.png}\", \"${6:.pdf}\"],",
      "            maxFileSize: ${7:5242880}",
      "        },",
      "        success: function (e) { console.log(\"Uploaded:\", e.files[0].name); }",
      "    });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo Upload widget"
  },

  "Kendo Window": {
    "prefix": "kendo-window",
    "body": [
      "<div id=\"${1:kendoWindow}\" style=\"display:none;\">",
      "    ${2:<!-- Window content here -->}",
      "</div>",
      "<button id=\"${1:kendoWindow}Btn\" class=\"k-button\">Open Window</button>",
      "",
      "@section Scripts {",
      "<script>",
      "$(document).ready(function () {",
      "    var win = $(\"#${1:kendoWindow}\").kendoWindow({",
      "        width: \"${3:600px}\",",
      "        title: \"${4:Window Title}\",",
      "        modal: true,",
      "        visible: false,",
      "        actions: [\"Minimize\", \"Maximize\", \"Close\"]",
      "    }).data(\"kendoWindow\");",
      "",
      "    $(\"#${1:kendoWindow}Btn\").click(function () { win.center().open(); });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo Window (modal dialog)"
  },

  "Kendo Notification": {
    "prefix": "kendo-notify",
    "body": [
      "<span id=\"${1:kendoNotify}\"></span>",
      "",
      "<script>",
      "var notifier = $(\"#${1:kendoNotify}\").kendoNotification({",
      "    position: { pinned: true, top: 30, right: 30 },",
      "    autoHideAfter: 3500,",
      "    stacking: \"down\",",
      "    templates: [{",
      "        type: \"success\",",
      "        template: \"<div class='k-notification-wrap'><span class='k-icon k-i-check'></span>#= message #</div>\"",
      "    }]",
      "}).data(\"kendoNotification\");",
      "",
      "// Usage: notifier.success({ message: \"Saved!\" });",
      "// Usage: notifier.error({ message: \"Failed!\" });",
      "// Usage: notifier.warning({ message: \"Warning\" });",
      "</script>"
    ],
    "description": "Kendo Notification widget"
  },

  "Kendo Validator": {
    "prefix": "kendo-validator",
    "body": [
      "var validator = $(\"#${1:formId}\").kendoValidator({",
      "    rules: {",
      "        ${2:customRule}: function (input) {",
      "            if (input.is(\"[data-${2:customRule}]\")) {",
      "                return ${3:true};",
      "            }",
      "            return true;",
      "        }",
      "    },",
      "    messages: {",
      "        ${2:customRule}: \"${4:Custom validation message}\"",
      "    }",
      "}).data(\"kendoValidator\");",
      "",
      "$(\"#${1:formId}\").on(\"submit\", function (e) {",
      "    e.preventDefault();",
      "    if (validator.validate()) {",
      "        // Submit logic",
      "    }",
      "});"
    ],
    "description": "Kendo Validator setup"
  },

  "Kendo Scheduler": {
    "prefix": "kendo-scheduler",
    "body": [
      "<div id=\"${1:kendoScheduler}\"></div>",
      "",
      "@section Scripts {",
      "<script>",
      "$(document).ready(function () {",
      "    $(\"#${1:kendoScheduler}\").kendoScheduler({",
      "        date: new Date(),",
      "        height: 600,",
      "        views: [\"day\", \"week\", { type: \"month\", selected: true }, \"agenda\"],",
      "        dataSource: {",
      "            batch: true,",
      "            transport: {",
      "                read:    { url: \"@Url.Action(\\\"Read\\\",   \\\"${2:Scheduler}\\\")\", type: \"POST\", dataType: \"json\" },",
      "                create:  { url: \"@Url.Action(\\\"Create\\\", \\\"${2:Scheduler}\\\")\", type: \"POST\", dataType: \"json\" },",
      "                update:  { url: \"@Url.Action(\\\"Update\\\", \\\"${2:Scheduler}\\\")\", type: \"POST\", dataType: \"json\" },",
      "                destroy: { url: \"@Url.Action(\\\"Delete\\\", \\\"${2:Scheduler}\\\")\", type: \"POST\", dataType: \"json\" },",
      "                parameterMap: function (data, type) {",
      "                    return type !== \"read\" ? JSON.stringify(data.models) : data;",
      "                }",
      "            },",
      "            schema: {",
      "                model: {",
      "                    id: \"TaskId\",",
      "                    fields: {",
      "                        TaskId: { type: \"number\" },",
      "                        title: { from: \"Title\", defaultValue: \"No title\" },",
      "                        start: { from: \"Start\", type: \"date\" },",
      "                        end:   { from: \"End\",   type: \"date\" }",
      "                    }",
      "                }",
      "            }",
      "        }",
      "    });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo Scheduler with CRUD"
  },

  "Kendo TabStrip": {
    "prefix": "kendo-tabs",
    "body": [
      "<div id=\"${1:kendoTabs}\">",
      "    <ul>",
      "        <li class=\"k-active\">${2:Tab One}</li>",
      "        <li>${3:Tab Two}</li>",
      "        <li>${4:Tab Three}</li>",
      "    </ul>",
      "    <div>${5:<!-- Tab 1 content -->}</div>",
      "    <div>${6:<!-- Tab 2 content -->}</div>",
      "    <div>${7:<!-- Tab 3 content -->}</div>",
      "</div>",
      "",
      "@section Scripts {",
      "<script>",
      "$(\"#${1:kendoTabs}\").kendoTabStrip({",
      "    animation: { open: { effects: \"fadeIn\" } }",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo TabStrip"
  },

  "Kendo AJAX JSON Action": {
    "prefix": "kendo-ajax",
    "body": [
      "$.ajax({",
      "    url: \"@Url.Action(\\\"${1:ActionName}\\\", \\\"${2:ControllerName}\\\")\",",
      "    type: \"POST\",",
      "    contentType: \"application/json\",",
      "    data: JSON.stringify({ ${3:key}: ${4:value} }),",
      "    success: function (response) {",
      "        if (response.success) {",
      "            kendo.alert(\"${5:Operation successful!}\");",
      "            ${6:// Handle success}",
      "        } else {",
      "            kendo.alert(response.message || \"An error occurred.\");",
      "        }",
      "    },",
      "    error: function (xhr) {",
      "        kendo.alert(\"Request failed: \" + xhr.statusText);",
      "    }",
      "});"
    ],
    "description": "AJAX call with Kendo alert handling"
  },

  "Kendo MVC Layout Scripts": {
    "prefix": "kendo-layout-scripts",
    "body": [
      "<link rel=\"stylesheet\" href=\"https://kendo.cdn.telerik.com/2024.1.130/styles/kendo.default-main.min.css\" />",
      "<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"></script>",
